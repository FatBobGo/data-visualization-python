# DataViz Environment Configuration
# Copy to .env and adjust values as needed.

# Application
APP_NAME=DataViz
APP_DESCRIPTION=Interactive Data Visualization Web App
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Upload Limits
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.csv,.tsv,.txt
